# ===========================
# AI 옷장 백엔드 환경 설정 예시
# 이 파일을 복사하여 .env 파일을 만드세요
# ===========================

# --- Database ---
# PostgreSQL 연결 URL
# 형식: postgresql+asyncpg://[유저]:[비밀번호]@[호스트]:[포트]/[DB명]
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/aicloset

# --- Storage ---
# 로컬 이미지 저장 경로 (backend/ 기준 상대 경로 또는 절대 경로)
STORAGE_BASE_PATH=./storage

# --- Pipeline ---
# 탐지 모델 구현체 선택: mock | yolo | faster_rcnn
DETECTOR_TYPE=mock
# 태깅 모델 구현체 선택: mock | vlm_openai | vlm_claude | fashionpedia
TAGGER_TYPE=mock

# --- App ---
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
